INSTALL_DIR="${SANDBOXED_COPILOT_DIR:-${HOME}/.sandboxed-copilot}"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.yml"
MODE_FILE="${INSTALL_DIR}/config/.mode"
RELEASES_FLAG_FILE="${INSTALL_DIR}/config/allow-github-releases"
COOLDOWN_FILE="${INSTALL_DIR}/config/package-cooldown"

# ---------------------------------------------------------------------------
# Per-session isolation: derive a stable hash from the current working directory
# so concurrent sessions in different projects each get their own proxy container,
# Docker networks, shell-history volume, and project-allowlist file.
# cksum is POSIX and available on macOS and Linux without extra tools.
# ---------------------------------------------------------------------------
COPILOT_WORKSPACE="$(pwd)"
export COPILOT_WORKSPACE
_session_hash=$(printf '%s' "$COPILOT_WORKSPACE" | cksum | awk '{printf "%08d", $1}')
_project_name="sandboxed-copilot-${_session_hash}"
PROJECT_ALLOWLIST_FILE="project-allowlist-${_session_hash}.txt"
PROJECT_ALLOWLIST="${INSTALL_DIR}/config/${PROJECT_ALLOWLIST_FILE}"
export PROJECT_ALLOWLIST_FILE

if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Error: sandboxed-copilot is not installed." >&2
    echo "Run install.sh from the sandboxed-copilot repository first." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# update subcommand
# ---------------------------------------------------------------------------
if [ "${1:-}" = "update" ]; then
    _installed_version=$(cat "${INSTALL_DIR}/VERSION" 2>/dev/null || echo "unknown")
    _source_dir=$(cat "${INSTALL_DIR}/source_dir" 2>/dev/null || true)
    _bin_dir="${HOME}/.local/bin"

    echo "Updating sandboxed-copilot..."
    echo ""
    echo "  Installed version : ${_installed_version}"

    _can_sync=false
    if [ -n "$_source_dir" ] && [ -f "${_source_dir}/Dockerfile" ]; then
        _source_version=$(cat "${_source_dir}/VERSION" 2>/dev/null || echo "unknown")
        echo "  Source version    : ${_source_version}  (${_source_dir})"
        _can_sync=true
    else
        echo "  Source directory  : not found (will rebuild images only)"
        if [ -n "$_source_dir" ]; then
            echo "  (expected at: ${_source_dir})"
        fi
    fi
    echo ""

    if [ "$_can_sync" = true ]; then
        echo "Syncing files from source..."

        # Docker build assets
        cp "${_source_dir}/Dockerfile"        "${INSTALL_DIR}/Dockerfile"
        cp "${_source_dir}/entrypoint.sh"     "${INSTALL_DIR}/entrypoint.sh"
        cp "${_source_dir}/docker-compose.yml" "${INSTALL_DIR}/docker-compose.yml"
        cp "${_source_dir}/uninstall.sh"      "${INSTALL_DIR}/uninstall.sh"
        chmod +x "${INSTALL_DIR}/uninstall.sh"

        # Proxy directory
        rm -rf "${INSTALL_DIR}/proxy"
        cp -r "${_source_dir}/proxy" "${INSTALL_DIR}/proxy"

        # Allowlist — preserve user customisations; write .new for diffing
        if [ ! -f "${INSTALL_DIR}/config/allowlist.txt" ]; then
            cp "${_source_dir}/config/allowlist.txt" "${INSTALL_DIR}/config/allowlist.txt"
            echo "  Created  ${INSTALL_DIR}/config/allowlist.txt"
        else
            cp "${_source_dir}/config/allowlist.txt" "${INSTALL_DIR}/config/allowlist.txt.new"
            echo "  Preserved ${INSTALL_DIR}/config/allowlist.txt"
            echo "  Written   ${INSTALL_DIR}/config/allowlist.txt.new  (diff and merge as needed)"
        fi

        # Version + source pointer
        cp "${_source_dir}/VERSION" "${INSTALL_DIR}/VERSION"
        printf '%s\n' "$_source_dir" > "${INSTALL_DIR}/source_dir"

        # Launcher script
        cp "${_source_dir}/sandboxed-copilot" "${_bin_dir}/sandboxed-copilot"
        chmod +x "${_bin_dir}/sandboxed-copilot"
        echo "  Updated  ${_bin_dir}/sandboxed-copilot"
        echo ""
    fi

    echo "Rebuilding Docker images (--pull refreshes base images)..."
    # Rebuild the proxy via docker compose (handles its own build context)
    docker compose \
        -f "${INSTALL_DIR}/docker-compose.yml" \
        --project-directory "${INSTALL_DIR}" \
        --project-name sandboxed-copilot \
        build --pull proxy

    # Rebuild all three copilot variant images explicitly
    for _v in minimal standard full; do
        echo "Building sandboxed-copilot-${_v} ..."
        docker build --pull --target "$_v" -t "sandboxed-copilot-${_v}" "$INSTALL_DIR"
    done

    # Remove the old single-image name (migration from pre-variants installs)
    docker rmi sandboxed-copilot-copilot 2>/dev/null || true

    _new_version=$(cat "${INSTALL_DIR}/VERSION" 2>/dev/null || echo "unknown")
    echo ""
    echo "✓ Update complete!  (version ${_new_version})"
    exit 0
fi

# ---------------------------------------------------------------------------
# Portable timestamp formatter (handles both macOS BSD date and GNU date)
# ---------------------------------------------------------------------------
format_timestamp() {
    local ts="$1"
    date -r "$ts" 2>/dev/null || date -d "@$ts" 2>/dev/null || echo "(unknown time)"
}

# ---------------------------------------------------------------------------
# _allowlist_add_domain <domain> <scope>
#   scope: "user"    → appends to INSTALL_DIR/config/allowlist.txt
#   scope: "project" → appends to [allowlist] section of .sandboxed-copilot
# ---------------------------------------------------------------------------
_allowlist_add_domain() {
    local domain="$1"
    local scope="$2"

    if [ "$scope" = "user" ]; then
        # Append to the global user allowlist; ensure it ends with a newline first.
        local file="${INSTALL_DIR}/config/allowlist.txt"
        # Avoid duplicates.
        if grep -qxF "$domain" "$file" 2>/dev/null; then
            echo "  (already in user allowlist: ${domain})"
            return 0
        fi
        printf '%s\n' "$domain" >> "$file"
        echo "  ✓ Added to user allowlist: ${domain}"
        echo "    (${file})"

    elif [ "$scope" = "project" ]; then
        local cfg="${COPILOT_WORKSPACE}/.sandboxed-copilot"

        # Avoid duplicates.
        if grep -qxF "$domain" "$cfg" 2>/dev/null; then
            echo "  (already in project config: ${domain})"
            return 0
        fi

        if [ ! -f "$cfg" ]; then
            # Create a minimal project config with an allowlist section.
            printf '[allowlist]\n%s\n' "$domain" > "$cfg"
        else
            # Check if [allowlist] section already exists.
            if grep -q '^\[allowlist\]' "$cfg"; then
                # Append after the last entry in [allowlist] (before the next section or EOF).
                # Use awk: once inside [allowlist], append domain before the next [section] line.
                awk -v dom="$domain" '
                    /^\[allowlist\]/ { in_al=1; print; next }
                    in_al && /^\[/ { print dom; in_al=0 }
                    { print }
                    END { if (in_al) print dom }
                ' "$cfg" > "${cfg}.tmp" && mv "${cfg}.tmp" "$cfg"
            else
                # Append [allowlist] section at end of file.
                printf '\n[allowlist]\n%s\n' "$domain" >> "$cfg"
            fi
        fi
        echo "  ✓ Added to project config: ${domain}"
        echo "    (${cfg})"
    fi
}

# ---------------------------------------------------------------------------
# cooldown subcommand — package dependency cooldown management
# Configures native minimum-release-age in npm, pnpm, uv, yarn, bun, and deno
# to mitigate supply chain attacks targeting newly published packages.
# Changes take effect on next container start.
# ---------------------------------------------------------------------------
if [ "${1:-}" = "cooldown" ]; then
    action="${2:-status}"
    case "$action" in
        disable)
            printf '0\n' > "$COOLDOWN_FILE"
            echo "✓ Package dependency cooldown disabled"
            echo "  npm, uv, yarn, bun, and deno will install packages of any age"
            echo "  (takes effect on next sandboxed-copilot session)"
            ;;
        status)
            if [ -f "$COOLDOWN_FILE" ]; then
                _days=$(cat "$COOLDOWN_FILE" | tr -d '[:space:]')
            else
                _days=0
            fi
            if [ "${_days:-0}" -gt 0 ] 2>/dev/null; then
                echo "Package cooldown: ${_days} day(s) (active)"
                echo "  npm/pnpm: NPM_CONFIG_MIN_RELEASE_AGE=${_days}d"
                echo "  uv:       UV_EXCLUDE_NEWER=${_days} days"
                echo "  yarn v4:  npmMinimalAgeGate: \"${_days}d\""
                echo "  bun:      minimumReleaseAge = \"${_days} days\""
                echo "  deno:     minimumDependencyAge: \"P${_days}D\""
            else
                echo "Package cooldown: disabled"
            fi
            ;;
        [0-9]*)
            printf '%s\n' "$action" > "$COOLDOWN_FILE"
            echo "✓ Package dependency cooldown set to ${action} day(s)"
            echo "  npm/pnpm, uv, yarn v4, bun, and deno will block packages"
            echo "  published within the last ${action} day(s)"
            echo "  (takes effect on next sandboxed-copilot session)"
            ;;
        *)
            echo "Usage: sandboxed-copilot cooldown {N|disable|status}" >&2
            echo "  N        set cooldown to N days (e.g. 7)" >&2
            echo "  disable  disable cooldown (allow all package ages)" >&2
            echo "  status   show current cooldown setting" >&2
            exit 1
            ;;
    esac
    exit 0
fi

# ---------------------------------------------------------------------------
# build subcommand — rebuild built-in variant images
# ---------------------------------------------------------------------------
if [ "${1:-}" = "build" ]; then
    _build_target="${2:-}"
    case "$_build_target" in
        minimal|standard|full)
            echo "Building sandboxed-copilot-${_build_target} ..."
            docker build --target "$_build_target" -t "sandboxed-copilot-${_build_target}" "$INSTALL_DIR"
            echo "✓ Built sandboxed-copilot-${_build_target}"
            ;;
        "")
            echo "Building all built-in variants (minimal, standard, full)..."
            echo "Note: the full variant includes Google Chrome and may take several minutes."
            echo ""
            for _v in minimal standard full; do
                echo "Building sandboxed-copilot-${_v} ..."
                docker build --target "$_v" -t "sandboxed-copilot-${_v}" "$INSTALL_DIR"
                echo "✓ Built sandboxed-copilot-${_v}"
                echo ""
            done
            echo "✓ All variants built."
            ;;
        *)
            echo "Usage: sandboxed-copilot build [minimal|standard|full]" >&2
            echo "  Omit the variant to rebuild all three." >&2
            exit 1
            ;;
    esac
    exit 0
fi

# ---------------------------------------------------------------------------
# proxy subcommand handler
# ---------------------------------------------------------------------------
if [ "${1:-}" = "proxy" ]; then
    subcmd="${2:-status}"

    case "$subcmd" in
        allow-all|enable)
            mins="${3:-30}"
            if ! [[ "$mins" =~ ^[0-9]+$ ]] || [ "$mins" -lt 1 ]; then
                echo "Error: duration must be a positive integer (minutes)." >&2
                exit 1
            fi
            expiry=$(( $(date +%s) + mins * 60 ))
            echo "allow-all:${expiry}" > "$MODE_FILE"
            echo "✓ Proxy opened for ${mins} minute(s) — auto-reverts at $(format_timestamp "$expiry")"
            echo "  (proxy container picks up the change within 5 seconds)"
            exit 0
            ;;

        lock)
            echo "lock" > "$MODE_FILE"
            echo "✓ Proxy locked — only minimum Copilot CLI domains are reachable"
            echo "  (proxy container picks up the change within 5 seconds)"
            exit 0
            ;;

        reset)
            rm -f "$MODE_FILE"
            echo "✓ Proxy reset — normal user allowlist restored"
            echo "  (proxy container picks up the change within 5 seconds)"
            exit 0
            ;;

        status)
            if [ ! -f "$MODE_FILE" ]; then
                echo "Proxy mode: normal (user allowlist)"
            else
                content=$(cat "$MODE_FILE" 2>/dev/null || echo "")
                if [[ "$content" == allow-all:* ]]; then
                    expiry="${content#allow-all:}"
                    now=$(date +%s)
                    if [ "$now" -lt "$expiry" ]; then
                        remaining=$(( (expiry - now + 59) / 60 ))
                        echo "Proxy mode: allow-all (expires in ~${remaining} minute(s) at $(format_timestamp "$expiry"))"
                    else
                        echo "Proxy mode: normal (allow-all expired — cleaning up)"
                        rm -f "$MODE_FILE"
                    fi
                elif [ "$content" = "lock" ]; then
                    echo "Proxy mode: lock (minimum Copilot domains only)"
                else
                    echo "Proxy mode: normal (user allowlist)"
                fi
            fi
            exit 0
            ;;

        denied)
            _show_all=0
            [ "${3:-}" = "--all" ] && _show_all=1

            # Verify the proxy container is running.
            _running=$(docker compose \
                -f "$COMPOSE_FILE" --project-directory "$INSTALL_DIR" \
                --project-name "$_project_name" \
                ps --services --filter status=running 2>/dev/null || true)
            if ! echo "$_running" | grep -q "^proxy$"; then
                echo "Error: proxy container is not running." >&2
                echo "Start it with: sandboxed-copilot" >&2
                exit 1
            fi

            # Determine the session start epoch (used to scope to current session).
            _session_start=0
            if [ "$_show_all" -eq 0 ]; then
                _container_id=$(docker compose \
                    -f "$COMPOSE_FILE" --project-directory "$INSTALL_DIR" \
                    --project-name "$_project_name" \
                    ps -q proxy 2>/dev/null | head -1)
                if [ -n "$_container_id" ]; then
                    _iso=$(docker inspect --format '{{.State.StartedAt}}' "$_container_id" 2>/dev/null || true)
                    if [ -n "$_iso" ]; then
                        # Convert ISO 8601 to epoch (handles both GNU and BSD date).
                        _session_start=$(date -d "$_iso" +%s 2>/dev/null || \
                                         date -j -f "%Y-%m-%dT%H:%M:%S" "${_iso%%.*}" +%s 2>/dev/null || \
                                         echo 0)
                    fi
                fi
            fi

            # Read the Squid access log from the proxy container, parse denied domains,
            # and filter out any that are already covered by the active allowlists.
            docker compose \
                -f "$COMPOSE_FILE" --project-directory "$INSTALL_DIR" \
                --project-name "$_project_name" \
                exec -T proxy cat /var/log/squid/access.log 2>/dev/null \
            | awk \
                -v session_start="$_session_start" \
                -v allowlist="${INSTALL_DIR}/config/allowlist.txt" \
                -v project_allowlist="${INSTALL_DIR}/config/${PROJECT_ALLOWLIST_FILE}" \
            'BEGIN {
                # Load both allowlists into a lookup array.
                n = split(allowlist ":" project_allowlist, files, ":")
                for (i = 1; i <= n; i++) {
                    while ((getline line < files[i]) > 0) {
                        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
                        if (line == "" || substr(line,1,1) == "#") continue
                        allowed[line] = 1
                    }
                    close(files[i])
                }
            }
            {
                # Field 1 is the Squid timestamp (epoch with milliseconds).
                ts = int($1)
                if (session_start > 0 && ts < session_start) next

                # Field 4 contains the result code (e.g. TCP_DENIED/403).
                if ($4 !~ /^TCP_DENIED/) next

                # Field 6 is the HTTP method; field 7 is the URL/host.
                method = $6
                url    = $7

                if (method == "CONNECT") {
                    # host:port — strip the port
                    domain = url
                    sub(/:[0-9]+$/, "", domain)
                } else {
                    # Full URL — extract the hostname
                    domain = url
                    sub(/^https?:\/\//, "", domain)
                    sub(/\/.*$/, "", domain)
                    sub(/:.*$/, "", domain)
                }

                if (domain == "" || domain == "-") next

                # Check if the domain is already covered by the allowlist.
                # A leading-dot entry (.foo.com) matches foo.com and *.foo.com.
                if (domain in allowed) next
                covered = 0
                for (entry in allowed) {
                    if (substr(entry, 1, 1) == ".") {
                        suffix = substr(entry, 2)
                        if (domain == suffix || \
                            substr(domain, length(domain) - length(suffix)) == "." suffix) {
                            covered = 1
                            break
                        }
                    }
                }
                if (covered) next

                domains[domain] = 1
            }
            END {
                for (d in domains) print d
            }' \
            | sort

            exit 0
            ;;

        allowlist)
            _domain_arg="${3:-}"

            # ── Collect the list of domains to process ──────────────────────
            declare -a _domains=()

            if [ -n "$_domain_arg" ]; then
                # Single domain passed as argument — go straight to scope prompt.
                _domains=("$_domain_arg")

            elif [ ! -t 0 ]; then
                # Stdin is a pipe — read one domain per line (e.g. from proxy denied).
                while IFS= read -r _line; do
                    _line="${_line//[[:space:]]/}"
                    [ -n "$_line" ] && _domains+=("$_line")
                done

            else
                # No argument, no pipe — run proxy denied automatically.
                echo "sandboxed-copilot: fetching blocked domains from proxy denied..." >&2
                while IFS= read -r _line; do
                    _line="${_line//[[:space:]]/}"
                    [ -n "$_line" ] && _domains+=("$_line")
                done < <(
                    bash "$0" proxy denied 2>/dev/null || true
                )
            fi

            if [ "${#_domains[@]}" -eq 0 ]; then
                echo "No blocked domains to add."
                exit 0
            fi

            # ── Interactive domain selection (skip if single domain passed) ──
            declare -a _selected=()

            if [ -n "$_domain_arg" ]; then
                _selected=("$_domain_arg")
            else
                # Show numbered list. Prompts must go to /dev/tty so they work
                # even when stdin is a pipe.
                exec 3</dev/tty
                echo ""
                echo "Blocked domains:"
                _i=1
                for _d in "${_domains[@]}"; do
                    printf "  %2d. %s\n" "$_i" "$_d"
                    _i=$(( _i + 1 ))
                done
                echo ""
                printf "Enter numbers to add (space-separated), 'all', or 'q' to quit: " >&2
                IFS= read -r _choice <&3

                if [ "$_choice" = "q" ] || [ -z "$_choice" ]; then
                    echo "Aborted."
                    exec 3<&-
                    exit 0
                fi

                if [ "$_choice" = "all" ]; then
                    _selected=("${_domains[@]}")
                else
                    for _num in $_choice; do
                        if [[ "$_num" =~ ^[0-9]+$ ]] && \
                           [ "$_num" -ge 1 ] && [ "$_num" -le "${#_domains[@]}" ]; then
                            _selected+=("${_domains[$(( _num - 1 ))]}")
                        else
                            echo "  Ignoring invalid selection: ${_num}" >&2
                        fi
                    done
                fi
                exec 3<&-
            fi

            if [ "${#_selected[@]}" -eq 0 ]; then
                echo "No domains selected."
                exit 0
            fi

            # ── Scope prompt ─────────────────────────────────────────────────
            exec 3</dev/tty
            echo ""
            echo "Add to:"
            echo "  1. User allowlist    (~/.sandboxed-copilot/config/allowlist.txt)"
            echo "  2. Project config    (.sandboxed-copilot in current directory)"
            printf "Choose [1/2]: " >&2
            IFS= read -r _scope_choice <&3
            exec 3<&-

            case "${_scope_choice:-1}" in
                1|u|user)    _scope="user" ;;
                2|p|project) _scope="project" ;;
                *)
                    echo "Invalid choice — defaulting to user allowlist." >&2
                    _scope="user"
                    ;;
            esac

            # ── Apply ─────────────────────────────────────────────────────────
            echo ""
            for _d in "${_selected[@]}"; do
                _allowlist_add_domain "$_d" "$_scope"
            done
            echo ""
            if [ "$_scope" = "user" ]; then
                echo "The proxy will reload within 5 seconds."
            else
                echo "Restart the sandbox session to apply the project allowlist changes."
            fi

            exit 0
            ;;

        monitor)
            # ── Discover all running proxy containers (all sessions) ──────────
            _monitor_containers=()
            _monitor_sessions=()
            while IFS=$'\t' read -r _cname _image; do
                if [[ "$_image" == *sandboxed-copilot-proxy* ]]; then
                    _monitor_containers+=("$_cname")
                    # Container name pattern: sandboxed-copilot-HASH-proxy-1
                    _mhash=$(printf '%s' "$_cname" | \
                        sed 's/.*sandboxed-copilot-\([0-9]*\)-.*/\1/' 2>/dev/null \
                        || printf '%s' "$_cname")
                    _monitor_sessions+=("$_mhash")
                fi
            done < <(docker ps --format '{{.Names}}\t{{.Image}}' 2>/dev/null)

            if [ "${#_monitor_containers[@]}" -eq 0 ]; then
                echo "No active sandbox sessions found." >&2
                echo "Start a session first with: sandboxed-copilot" >&2
                exit 1
            fi

            # ── ANSI colour codes ─────────────────────────────────────────────
            _mc_green='\033[0;32m'
            _mc_red='\033[0;31m'
            _mc_amber='\033[0;33m'
            _mc_bold='\033[1m'
            _mc_dim='\033[2m'
            _mc_reset='\033[0m'

            # ── Header ────────────────────────────────────────────────────────
            printf '\n'
            printf "${_mc_bold}  sandboxed-copilot proxy monitor${_mc_reset}"
            printf "  ${_mc_dim}%d active session(s) — Ctrl-C to stop${_mc_reset}\n" \
                "${#_monitor_containers[@]}"
            printf '\n'
            printf "  ${_mc_bold}%-8s  %-10s  %-8s  %-61s  %s${_mc_reset}\n" \
                "TIME" "SESSION" "METHOD" "URI" "STATUS"
            printf '  %s\n' \
                "────────────────────────────────────────────────────────────────────────────────────────"

            # ── Fan-in via named FIFO ─────────────────────────────────────────
            # Why FIFO + exec 4<> (not { } | while with pipefail):
            #   With set -euo pipefail, if docker exec fails the { } subshell
            #   exits non-zero, pipefail propagates it, and -e kills the script
            #   instantly. The FIFO approach avoids pipelines entirely.
            #
            # How it works:
            #   exec 4<>"$fifo"  — O_RDWR open: non-blocking, keeps write end
            #                      open so the while-loop reader never sees an
            #                      early EOF even before writers connect.
            #   (cmd) >> "$fifo" — each background writer opens a new O_WRONLY
            #                      fd; doesn't block because fd 4 already holds
            #                      the read end open.
            #   done < "$fifo"   — O_RDONLY open; doesn't block because fd 4
            #                      holds the write end open; loop runs until
            #                      Ctrl-C closes fd 4 (or all writers die).
            _mon_fifo=$(mktemp -u /tmp/sc-monitor-XXXXXX)
            mkfifo "$_mon_fifo"
            exec 4<>"$_mon_fifo"   # keepalive: O_RDWR, non-blocking

            _monitor_bg_pids=()
            _monitor_cleanup() {
                exec 4>&-           # close keepalive → reader sees EOF if idle
                for _mpid in "${_monitor_bg_pids[@]}"; do
                    kill "$_mpid" 2>/dev/null || true
                done
                rm -f "$_mon_fifo"
                printf '\n'
            }
            trap '_monitor_cleanup; exit 0' INT TERM

            # One background writer per proxy container.
            # tail -n 10 shows the 10 most-recent entries on startup, then follows.
            # Stdin redirected from /dev/null so docker exec doesn't need -T/-i.
            # fflush() ensures awk doesn't buffer when writing to the FIFO.
            _mi=0
            for _mcname in "${_monitor_containers[@]}"; do
                _mh="${_monitor_sessions[$_mi]}"
                _mi=$((_mi + 1))
                # ── access.log: regular allowed/denied traffic ──────────────
                (
                    docker exec "$_mcname" \
                        tail -n 10 -f /var/log/squid/access.log \
                        </dev/null 2>/dev/null | \
                        awk -v h="$_mh" 'index($0, "transaction-end-before-headers") == 0 { print h "\t" $0; fflush() }'
                ) >> "$_mon_fifo" &
                _monitor_bg_pids+=($!)
                # ── exfil.log: token exfiltration detections (ACL + ICAP) ───
                (
                    docker exec "$_mcname" \
                        tail -n 10 -f /var/log/squid/exfil.log \
                        </dev/null 2>/dev/null | \
                        awk -v h="$_mh" '{ print "[exfil]\t" h "\t" $0; fflush() }'
                ) >> "$_mon_fifo" &
                _monitor_bg_pids+=($!)
            done

            # ── Format and display ────────────────────────────────────────────
            # FIFO entries are tab-separated. Two source types:
            #
            # Regular traffic (access.log):
            #   <session>\t<squid-log-line>
            #   Squid log fields: 1:ts 2:elapsed 3:client 4:result/status 5:bytes
            #                     6:method 7:url 8:user 9:hierarchy 10:mime
            #
            # Exfil detections (exfil.log — both Squid ACL and ICAP body scan):
            #   [exfil]\t<session>\t<log-line>
            #
            #   ACL detection format (Squid exfil_fmt logformat):
            #     timestamp client method url http-status
            #
            #   ICAP body detection format (written by icap-scanner):
            #     ICAP timestamp client method url http-status detection:<location>
            #
            # With ssl_bump active, each HTTPS request produces two access.log entries:
            #   a) NONE_NONE/200 CONNECT hostname:443  — bump establishment (filtered)
            #   b) TCP_MISS/200  GET https://hostname/path — actual request (shown)
            # For denied requests:
            #   a) TCP_DENIED/200 CONNECT hostname:443 — blocked (shown, hostname only)
            #   b) NONE_NONE/403 GET https://hostname/ — error page (shown, full URI)
            while IFS=$'\t' read -r _mfirst _msecond _mrest; do

                # ── Exfil detection entry ─────────────────────────────────────
                if [ "$_mfirst" = "[exfil]" ]; then
                    _mexsession="$_msecond"
                    _mexline="$_mrest"

                    # ICAP body detection: "ICAP ts client METHOD url status detection:loc"
                    # ACL detection:       "ts client METHOD dest-host status"
                    if [[ "$_mexline" == ICAP\ * ]]; then
                        read -r _ _mets _ _memethod _meurl _ _medloc <<< "$_mexline"
                        _meloc="(body)"
                    elif [[ "$_mexline" =~ ^[0-9] ]]; then
                        read -r _mets _ _memethod _meurl _ <<< "$_mexline"
                        _meloc=""
                    else
                        # Not a recognised detection format (e.g. scanner startup log
                        # that somehow ended up in exfil.log). Skip silently.
                        continue
                    fi

                    _metime=$(date -r "${_mets%%.*}" '+%H:%M:%S' 2>/dev/null || \
                              date -d "@${_mets%%.*}" '+%H:%M:%S' 2>/dev/null || \
                              printf '%s' "${_mets%%.*}")

                    if [ "${#_meurl}" -gt 60 ]; then
                        _meurl="${_meurl:0:59}…"
                    fi

                    printf "  ${_mc_amber}%-8s  %-10s  %-8s  %-61s  ⚠ EXFIL %s${_mc_reset}\n" \
                        "$_metime" "$_mexsession" "$_memethod" "$_meurl" "$_meloc"
                    continue
                fi

                # ── Regular access.log entry ──────────────────────────────────
                # The FIFO writer outputs: <session>\t<squid-log-line>
                # When _mfirst is not "[exfil]", _mfirst=session, _msecond is the
                # first field of the log line, and _mrest is the remaining fields.
                _msession="$_mfirst"
                _mline="${_msecond}${_mrest:+ }${_mrest}"
                read -r _mts _ _ _mresult _ _mmethod _murl _ <<< "$_mline"

                # Skip ssl_bump establishment entries (NONE_NONE CONNECT with 2xx/000).
                # These are squid's bookkeeping for the TLS handshake — every allowed
                # HTTPS request generates one. The actual request follows as TCP_MISS.
                if [ "$_mmethod" = "CONNECT" ] && [[ "$_mresult" == NONE_NONE* ]]; then
                    continue
                fi

                # Build the display URI:
                #   CONNECT entries (denied domains): show hostname only, strip :port
                #   All other methods: show full URL as logged by squid
                if [ "$_mmethod" = "CONNECT" ]; then
                    _muri="${_murl%%:*}"
                else
                    _muri="${_murl}"
                fi

                # Truncate long URIs to fit the column; append ellipsis if truncated
                if [ "${#_muri}" -gt 60 ]; then
                    _muri="${_muri:0:59}…"
                fi

                # Human-readable time from Unix epoch (BSD and GNU date)
                _mtime=$(date -r "${_mts%%.*}" '+%H:%M:%S' 2>/dev/null || \
                         date -d "@${_mts%%.*}" '+%H:%M:%S' 2>/dev/null || \
                         printf '%s' "${_mts%%.*}")

                # Denied detection:
                #   TCP_DENIED — blocked by squid ACL at the CONNECT stage
                #   NONE_NONE with HTTP status ≥ 400 — squid error page (post-deny)
                _mhttpcode="${_mresult#*/}"
                if [[ "$_mresult" == TCP_DENIED* ]] || \
                   { [[ "$_mresult" == NONE_NONE* ]] && [ "${_mhttpcode:-0}" -ge 400 ] 2>/dev/null; }; then
                    printf "  ${_mc_red}%-8s  %-10s  %-8s  %-61s  ✗ DENIED${_mc_reset}\n" \
                        "$_mtime" "$_msession" "$_mmethod" "$_muri"
                else
                    printf "  ${_mc_green}%-8s  %-10s  %-8s  %-61s  ✓ allowed${_mc_reset}\n" \
                        "$_mtime" "$_msession" "$_mmethod" "$_muri"
                fi
            done < "$_mon_fifo"

            _monitor_cleanup
            exit 0
            ;;

        releases)
            action="${3:-status}"
            case "$action" in
                enable)
                    touch "$RELEASES_FLAG_FILE"
                    echo "✓ GitHub releases enabled"
                    echo "  uploads.github.com and POST /repos/*/releases are now allowed"
                    echo "  Note: repository creation (POST /user/repos, POST /orgs/*/repos) remains blocked"
                    echo "  (proxy container picks up the change within 5 seconds)"
                    ;;
                disable)
                    rm -f "$RELEASES_FLAG_FILE"
                    echo "✓ GitHub releases disabled (default)"
                    echo "  uploads.github.com and release creation are now blocked"
                    echo "  (proxy container picks up the change within 5 seconds)"
                    ;;
                status)
                    if [ -f "$RELEASES_FLAG_FILE" ]; then
                        echo "GitHub releases: enabled"
                    else
                        echo "GitHub releases: disabled (default)"
                    fi
                    ;;
                *)
                    echo "Usage: sandboxed-copilot proxy releases [enable|disable|status]" >&2
                    exit 1
                    ;;
            esac
            exit 0
            ;;

        *)
            echo "Unknown proxy subcommand: $subcmd" >&2
            echo "Usage: sandboxed-copilot proxy {allow-all|enable|lock|reset|status|denied|allowlist|monitor|releases} [args]" >&2
            exit 1
            ;;
    esac
fi

# ---------------------------------------------------------------------------
# Default: launch the copilot container
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Image selection: --image flag > positional variant > project config > default
# Resolved here, before project config parsing, so [image] section can be
# overridden by command-line flags.
# ---------------------------------------------------------------------------
_copilot_image=""
_custom_dockerfile=""
_image_is_builtin=true  # true = one of our built-in images; false = custom

# Parse --image flag first (highest precedence after positional variant)
if [ "${1:-}" = "--image" ]; then
    if [ -z "${2:-}" ]; then
        echo "Error: --image requires a Docker image name" >&2
        exit 1
    fi
    _copilot_image="$2"
    _image_is_builtin=false
    shift 2
fi

# Parse positional variant (minimal / standard / full) — mutually exclusive with --image
if [ -z "$_copilot_image" ]; then
    case "${1:-}" in
        minimal|standard|full)
            _copilot_image="sandboxed-copilot-$1"
            shift
            ;;
    esac
fi

# Build the list of extra docker flags for git identity support.
DOCKER_EXTRA=()

# Mount the host git config so commits use the operator's name, email, and
# signing settings rather than a generic "copilot" identity.
if [ -f "${HOME}/.gitconfig" ]; then
    DOCKER_EXTRA+=(-v "${HOME}/.gitconfig:/home/copilot/.gitconfig:ro")
fi
# Also mount the XDG git config location if present.
if [ -f "${HOME}/.config/git/config" ]; then
    DOCKER_EXTRA+=(-v "${HOME}/.config/git/config:/home/copilot/.config/git/config:ro")
fi

# Mount the host Copilot configuration (skills, MCP servers, preferences) read-only
# so the agent has access to the same skills the user has configured on the host.
if [ -d "${HOME}/.config/github-copilot" ]; then
    DOCKER_EXTRA+=(-v "${HOME}/.config/github-copilot:/home/copilot/.config/github-copilot:ro")
fi

# Trust the mounted workspace (git 2.35.2+ safe.directory check).
# The workspace is mounted from the host and may have a different UID owner
# than the container user; this env-level override avoids "dubious ownership"
# errors without modifying the user's gitconfig.
DOCKER_EXTRA+=(-e GIT_CONFIG_COUNT=1 -e GIT_CONFIG_KEY_0=safe.directory -e GIT_CONFIG_VALUE_0=/workspace)

# ---------------------------------------------------------------------------
# Per-project config (.sandboxed-copilot in the project root)
# Always reset the project allowlist first so the previous project's domains
# don't leak into the current session.
# ---------------------------------------------------------------------------
printf '' > "$PROJECT_ALLOWLIST"

if [ -f "$(pwd)/.sandboxed-copilot" ]; then
    _section=""
    while IFS= read -r _line || [ -n "$_line" ]; do
        # Strip inline comments and all whitespace.
        # Domain names and env var names never contain spaces, so this is safe.
        _line="${_line%%#*}"
        _line="${_line//[[:space:]]/}"
        [ -z "$_line" ] && continue

        if [[ "$_line" == '['*']' ]]; then
            _section="${_line:1:-1}"
        elif [ "$_section" = "allowlist" ]; then
            printf '%s\n' "$_line" >> "$PROJECT_ALLOWLIST"
        elif [ "$_section" = "env" ]; then
            if [[ "$_line" == *=* ]]; then
                # NAME=value — forward with an explicit literal value
                DOCKER_EXTRA+=(-e "$_line")
            else
                # NAME — read the current value from the host environment
                _val=$(printenv "$_line" 2>/dev/null || true)
                DOCKER_EXTRA+=(-e "${_line}=${_val}")
            fi
        elif [ "$_section" = "image" ] && [ -z "$_copilot_image" ]; then
            # [image] section: only applied if no --image flag or positional variant was given.
            # Supported keys: variant, name, dockerfile (mutually exclusive)
            if [[ "$_line" == variant=* ]]; then
                _cfg_variant="${_line#variant=}"
                case "$_cfg_variant" in
                    minimal|standard|full)
                        _copilot_image="sandboxed-copilot-${_cfg_variant}"
                        ;;
                    *)
                        echo "sandboxed-copilot: warning: unknown variant '${_cfg_variant}' in [image] section; using standard" >&2
                        ;;
                esac
            elif [[ "$_line" == name=* ]]; then
                _copilot_image="${_line#name=}"
                _image_is_builtin=false
            elif [[ "$_line" == dockerfile=* ]]; then
                _custom_dockerfile="${_line#dockerfile=}"
                _image_is_builtin=false
            fi
        fi
    done < "$(pwd)/.sandboxed-copilot"
    echo "sandboxed-copilot: loaded project config (.sandboxed-copilot)" >&2
fi

# ---------------------------------------------------------------------------
# Resolve final image + handle custom Dockerfile auto-build
# ---------------------------------------------------------------------------

# Apply COPILOT_IMAGE env var fallback (lower priority than CLI flags / project config)
if [ -z "$_copilot_image" ] && [ -n "${COPILOT_IMAGE:-}" ]; then
    _copilot_image="$COPILOT_IMAGE"
    # Determine if it looks like a built-in image
    case "$_copilot_image" in
        sandboxed-copilot-minimal|sandboxed-copilot-standard|sandboxed-copilot-full)
            _image_is_builtin=true ;;
        *)
            _image_is_builtin=false ;;
    esac
fi

# Default to standard if nothing was selected
if [ -z "$_copilot_image" ] && [ -z "$_custom_dockerfile" ]; then
    _copilot_image="sandboxed-copilot-standard"
    _image_is_builtin=true
fi

# Handle custom Dockerfile: build image if missing or Dockerfile changed
if [ -n "$_custom_dockerfile" ]; then
    # Resolve relative path from the project workspace
    if [[ "$_custom_dockerfile" != /* ]]; then
        _custom_dockerfile="${COPILOT_WORKSPACE}/${_custom_dockerfile#./}"
    fi

    if [ ! -f "$_custom_dockerfile" ]; then
        echo "Error: custom Dockerfile not found: ${_custom_dockerfile}" >&2
        exit 1
    fi

    # Warn if the Dockerfile doesn't extend a built-in variant
    if ! head -5 "$_custom_dockerfile" | grep -q 'FROM sandboxed-copilot-'; then
        echo "sandboxed-copilot: warning: custom Dockerfile does not extend a built-in variant." >&2
        echo "  For full proxy/CA cert compatibility, use: FROM sandboxed-copilot-standard" >&2
    fi

    # Image tag is stable per-project (based on workspace hash)
    _copilot_image="sandboxed-copilot-custom-${_session_hash}"

    # Compute content hash of the Dockerfile to detect changes
    _df_hash=$(sha256sum "$_custom_dockerfile" | awk '{print $1}')
    _hash_file="${INSTALL_DIR}/config/custom-image-hashes"
    _stored_hash=$(grep "^${_session_hash} " "$_hash_file" 2>/dev/null | awk '{print $2}' || true)

    _needs_build=false
    if ! docker image inspect "$_copilot_image" >/dev/null 2>&1; then
        _needs_build=true
        echo "sandboxed-copilot: custom image not found — building from ${_custom_dockerfile} ..." >&2
    elif [ "$_df_hash" != "$_stored_hash" ]; then
        _needs_build=true
        echo "sandboxed-copilot: custom Dockerfile has changed — rebuilding ..." >&2
    fi

    if [ "$_needs_build" = true ]; then
        docker build -f "$_custom_dockerfile" -t "$_copilot_image" "$COPILOT_WORKSPACE"
        # Update stored hash
        _tmp_hash=$(mktemp)
        grep -v "^${_session_hash} " "$_hash_file" 2>/dev/null > "$_tmp_hash" || true
        printf '%s %s\n' "$_session_hash" "$_df_hash" >> "$_tmp_hash"
        mv "$_tmp_hash" "$_hash_file"
    fi
fi

# Warn if using a non-built-in image (proxy CA cert may not be trusted)
if [ "$_image_is_builtin" = false ]; then
    echo "sandboxed-copilot: using custom image: ${_copilot_image}" >&2
    echo "  Note: HTTPS may not work if the proxy CA cert is not trusted by this image." >&2
    echo "  For full compatibility, extend FROM sandboxed-copilot-base in your Dockerfile." >&2
    # Inject proxy env vars explicitly so they are set even if not in the image
    DOCKER_EXTRA+=(-e "HTTP_PROXY=http://proxy:3128" -e "HTTPS_PROXY=http://proxy:3128")
    DOCKER_EXTRA+=(-e "http_proxy=http://proxy:3128" -e "https_proxy=http://proxy:3128")
    DOCKER_EXTRA+=(-e "NO_PROXY=localhost,127.0.0.1" -e "no_proxy=localhost,127.0.0.1")
fi

# Auto-build built-in image if it doesn't exist yet (e.g. first use of 'full' variant)
if [ "$_image_is_builtin" = true ] && ! docker image inspect "$_copilot_image" >/dev/null 2>&1; then
    _variant="${_copilot_image#sandboxed-copilot-}"
    echo "sandboxed-copilot: image ${_copilot_image} not found — building (first use of ${_variant} variant)..." >&2
    docker build --target "$_variant" -t "$_copilot_image" "$INSTALL_DIR"
fi

# Export for docker-compose.yml substitution
export COPILOT_IMAGE="$_copilot_image"

# ---------------------------------------------------------------------------
# Cleanup: remove the session-specific project allowlist when the session ends.
# Each session has its own file so this only affects the current workspace session.
# ---------------------------------------------------------------------------
_cleanup() {
    rm -f "$PROJECT_ALLOWLIST" 2>/dev/null || true
}
trap _cleanup EXIT

# ---------------------------------------------------------------------------
# GITHUB_TOKEN auto-detection
# If the user hasn't exported GITHUB_TOKEN, try to get it from the host gh CLI.
# An explicit GITHUB_TOKEN always wins.
# ---------------------------------------------------------------------------
if [ -z "${GITHUB_TOKEN:-}" ] && command -v gh &>/dev/null; then
    _detected_token=$(gh auth token 2>/dev/null || true)
    if [ -n "$_detected_token" ]; then
        GITHUB_TOKEN="$_detected_token"
        echo "sandboxed-copilot: ✓ Using token from gh auth" >&2
    fi
fi

# COPILOT_WORKSPACE is set at the top of the script and read by docker-compose.yml
# to bind-mount the current directory at /workspace.
GITHUB_TOKEN="${GITHUB_TOKEN:-}" \
docker compose \
    -f "$COMPOSE_FILE" \
    --project-directory "$INSTALL_DIR" \
    --project-name "$_project_name" \
    run --rm \
    "${DOCKER_EXTRA[@]}" \
    copilot "$@"
