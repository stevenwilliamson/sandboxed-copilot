                    if (( CURRENT == 3 )); then
                        case ${line[2]} in
                            denied)
                                _arguments '--all[show full log history]'
                                ;;
                            allow-all|enable)
                                _message 'minutes (default: 30)'
                                ;;
                            allowlist)
                                _message 'domain (optional)'
                                ;;
                            releases)
                                local release_actions=('enable:allow GitHub release creation and uploads' 'disable:block GitHub release creation and uploads' 'status:show whether releases are currently allowed')
                                _describe 'action' release_actions
                                ;;
                            *)
                                local proxy_cmds=(
                                    'allow-all:open all outbound traffic (default 30 min)'
                                    'enable:same as allow-all'
                                    'lock:restrict to minimum Copilot domains only'
                                    'reset:restore normal user allowlist'
                                    'status:show current proxy mode'
                                    'denied:list domains blocked by the proxy'
                                    'allowlist:add domain(s) to the allowlist interactively'
                                    'monitor:live colour-coded view of all proxy traffic'
                                    'releases:toggle GitHub release creation and uploads'
                                )
                                _describe 'proxy subcommand' proxy_cmds
                                ;;
                        esac
                    elif (( CURRENT == 2 )); then
                        local proxy_cmds=(
                            'allow-all:open all outbound traffic (default 30 min)'
                            'enable:same as allow-all'
                            'lock:restrict to minimum Copilot domains only'
                            'reset:restore normal user allowlist'
                            'status:show current proxy mode'
                            'denied:list domains blocked by the proxy'
                            'allowlist:add domain(s) to the allowlist interactively'
                            'monitor:live colour-coded view of all proxy traffic'
                            'releases:toggle GitHub release creation and uploads'
                        )
                        _describe 'proxy subcommand' proxy_cmds
                    fi
                    ;;
                completion)
                    local shells=('bash:Bash completion script' 'zsh:Zsh completion script' 'fish:Fish completion script')
                    _describe 'shell' shells
                    ;;
                cooldown)
                    local cooldown_actions=('disable:disable cooldown (allow all package ages)' 'status:show current cooldown setting')
                    _describe 'action' cooldown_actions
                    ;;
                build)
                    local build_variants=('minimal:rebuild the minimal variant' 'standard:rebuild the standard variant' 'full:rebuild the full variant')
                    _describe 'variant' build_variants
                    ;;
            esac
            ;;
    esac
}
_sandboxed_copilot
ZSH_COMPLETION
            ;;
        fish)
            cat <<'FISH_COMPLETION'
